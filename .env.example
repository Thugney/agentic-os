# Agentic OS local configuration
AGENTIC_OS_ENVIRONMENT=production
AGENTIC_OS_ADMIN_TOKEN=change-this-long-random-token
AGENTIC_OS_DATA_DIR=/data
AGENTIC_OS_APP_HOST=0.0.0.0
AGENTIC_OS_APP_PORT=3737
AGENTIC_OS_PUBLIC_URL=http://0.0.0.0:3737
AGENTIC_OS_CONFIG_DIR=config

# DeepSeek cloud API. Add DEEPSEEK_API_KEY in your local .env only; never commit it.
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional local/custom OpenAI-compatible endpoint only if you choose it later.
OPENWEBUI_URL=http://127.0.0.1:18790
# If needed, add OPENWEBUI_API_KEY in local .env only.

# Codex/Claude subscription mode requires authenticated CLI adapters where Agentic OS can reach them.
# CODEX_CLI=codex
# CLAUDE_CLI=claude

# Hermes gateway/API. This is NOT the dashboard port. The dashboard command below only exposes UI:
# hermes dashboard --host 0.0.0.0 --port 9119 --no-open --insecure
HERMES_URL=http://192.168.1.118:8642

# Used by Agentic OS when sending chat through the Hermes API-server OpenAI-compatible route.
HERMES_API_MODEL=hermes-agent

# Optional profile routing header. Use this only if your Hermes API server supports profile selection by header.
# HERMES_PROFILE=default

# Optional bearer token if your Hermes API server requires one. Add HERMES_API_KEY in local .env only.
# Optional: path/name for Hermes CLI bridge used only if no HERMES_URL is configured.
# HERMES_CLI=hermes
# HERMES_CHAT_TIMEOUT=180
